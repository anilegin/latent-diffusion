model:
  name: latent_diffusion_unet_light

  in_channels: 8
  out_channels: 8

  # 256x256 image with VAE downsample factor 8 gives 32x32 latent.
  latent_size: 32

  # Lightweight U-Net width.
  base_channels: 128

  # Channel path:
  # 32x32: 128
  # 16x16: 256
  # 8x8:   384
  #
  # This is lighter than [1, 2, 4].
  channel_multipliers: [1, 2, 3]

  num_res_blocks: 2
  dropout: 0.0

  # Text-conditioned attention only at low resolutions.
  attention_resolutions: [16, 8]

  # Middle block at 8x8 uses attention.
  use_middle_attention: true

  # CLIP ViT-L/14 hidden size.
  context_dim: 768

  # Lightweight attention:
  # inner attention dim = num_heads * head_dim = 4 * 32 = 128
  num_heads: 4
  head_dim: 32

  transformer_depth: 1

  # If null, code uses base_channels * 4.
  time_embedding_dim: null